# Copy this file to .env and fill in the keys for the providers you use.

# OpenAI — required for personas using provider: openai (standard)
OPENAI_API_KEY=sk-...

# Azure OpenAI — used automatically when base_url is set in the persona config
AZURE_OPENAI_API_KEY=...

# Google Gemini — required for personas using provider: gemini
GOOGLE_API_KEY=...

# Ollama runs locally — no API key needed, but you can override the host:
# OLLAMA_HOST=http://localhost:11434
